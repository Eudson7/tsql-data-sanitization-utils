WITH DBO_PONTOS_MOCK AS (
    SELECT 
        'Praça Deodoro até Igreja da Sé' AS Descricao,
        -2.529815 AS Lat_Origem, -44.302521 AS Lon_Origem, 
        -2.529068 AS Lat_Destino, -44.306800 AS Lon_Destino  
)
SELECT 
    Descricao,
    dbo.fn_Geo_CalcularDistancia(Lat_Origem, Lon_Origem, Lat_Destino, Lon_Destino, 'M') AS Distancia_Metros,
    dbo.fn_Geo_CalcularDistancia(Lat_Origem, Lon_Origem, Lat_Destino, Lon_Destino, 'KM') AS Distancia_KM
FROM DBO_PONTOS_MOCK;
