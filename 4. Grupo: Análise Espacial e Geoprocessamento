-- 1. Cálculo de Distância Linear entre Coordenadas (Suporta retornos em 'M' ou 'KM') --------------------------------------------------
CREATE FUNCTION dbo.fn_Geo_CalcularDistancia (
    @Lat1 FLOAT,
    @Lon1 FLOAT,
    @Lat2 FLOAT,
    @Lon2 FLOAT,
    @Unidade VARCHAR(2) -- 'M' para Metros, 'KM' para Quilômetros
)
RETURNS FLOAT
AS
BEGIN
    DECLARE @Ponto1 GEOGRAPHY;
    DECLARE @Ponto2 GEOGRAPHY;
    DECLARE @Distancia FLOAT;

    -- Validação de segurança: Se alguma coordenada ou unidade for nula, retorna nulo
    IF @Lat1 IS NULL OR @Lon1 IS NULL OR @Lat2 IS NULL OR @Lon2 IS NULL OR @Unidade IS NULL
        RETURN NULL;

    -- O número 4326 representa o WGS84 (padrão mundial do GPS)
    SET @Ponto1 = GEOGRAPHY::STGeomFromText('POINT(' + CAST(@Lon1 AS VARCHAR(20)) + ' ' + CAST(@Lat1 AS VARCHAR(20)) + ')', 4326);
    SET @Ponto2 = GEOGRAPHY::STGeomFromText('POINT(' + CAST(@Lon2 AS VARCHAR(20)) + ' ' + CAST(@Lat1 AS VARCHAR(20)) + ')', 4326);

    -- Calcula a distância nativa em metros
    SET @Distancia = @Ponto1.STDistance(@Ponto2);

    -- Aplica a conversão se o usuário pedir em Quilômetros
    IF UPPER(@Unidade) = 'KM'
    BEGIN
        SET @Distancia = @Distancia / 1000.0;
    END

    RETURN @Distancia;
END;
GO

-- SCRIPT DE TESTE: fn_Geo_CalcularDistancia
-- Mudando apenas a flag da unidade ("M" ou "KM") na chamada da função para ter o resultado desejado
WITH DBO_PONTOS_MOCK AS (
    SELECT 
        'Praça Deodoro até Igreja da Sé' AS Descricao,
        -2.529815 AS Lat_Origem, -44.302521 AS Lon_Origem, 
        -2.529068 AS Lat_Destino, -44.306800 AS Lon_Destino  
)
SELECT 
    Descricao,
    dbo.fn_Geo_CalcularDistancia(Lat_Origem, Lon_Origem, Lat_Destino, Lon_Destino, 'M') AS Distancia_Metros, -- flag da unidade "M"
    dbo.fn_Geo_CalcularDistancia(Lat_Origem, Lon_Origem, Lat_Destino, Lon_Destino, 'KM') AS Distancia_KM -- flag da unidade "KM"
FROM DBO_PONTOS_MOCK;
GO


-- 2. Cálculo de Área de um Polígono Geográfico (Suporta GEOGRAPHY e auto-correção de hemisfério) --------------------------------------------------------
CREATE FUNCTION dbo.fn_Geo_CalcularAreaPoligono (
    @Geometria GEOGRAPHY,
    @Unidade VARCHAR(3) -- 'M2' para Metros Quadrados, 'KM2' para Quilômetros Quadrados
)
RETURNS FLOAT
AS
BEGIN
    -- Validação de segurança para evitar erros de execução com dados nulos
    IF @Geometria IS NULL OR @Unidade IS NULL
        RETURN NULL;

    -- O método .ReorientObject() detecta e corrige automaticamente polígonos invertidos
    DECLARE @Area FLOAT = @Geometria.ReorientObject().STArea();

    -- Aplica a conversão matemática caso o usuário solicite em Quilômetros Quadrados
    IF UPPER(@Unidade) = 'KM2'
    BEGIN
        SET @Area = @Area / 1000000.0;
    END

    RETURN @Area;
END;
GO

-- SCRIPT DE TESTE: fn_Geo_CalcularAreaPoligono
-- O teste abaixo valida a função usando um polígono normal e um polígono invertido na memória
WITH DBO_POLIGONO_MOCK AS (
    SELECT 
        'Polígono Orientação Correta' AS Descricao,
        -- Desenhado no sentido horário (Normal)
        GEOGRAPHY::STGeomFromText('POLYGON((-44.30 -2.50, -44.30 -2.51, -44.31 -2.51, -44.31 -2.50, -44.30 -2.50))', 4326) AS GeoDado
    UNION ALL
    SELECT 
        'Polígono Orientação Invertida (Anti-Horário)' AS Descricao,
        -- Desenhado no sentido anti-horário (Estouraria o hemisfério sem o ReorientObject)
        GEOGRAPHY::STGeomFromText('POLYGON((-44.30 -2.50, -44.31 -2.50, -44.31 -2.51, -44.30 -2.51, -44.30 -2.50))', 4326) AS GeoDado
)
SELECT 
    Descricao,
    ROUND(dbo.fn_Geo_CalcularAreaPoligono(GeoDado, 'M2'), 2)  AS Area_Metros_Quadrados,
    ROUND(dbo.fn_Geo_CalcularAreaPoligono(GeoDado, 'KM2'), 2) AS Area_KM_Quadrados
FROM DBO_POLIGONO_MOCK;
GO
