-- 1.1. Remoção de Acentuação com Tratamento Binário (Blindado para Collation CI_AI - Case Insensitive (CI) e Accent Insensitive (AI) - banco de dados com Case Sensitive desativado)
CREATE FUNCTION dbo.fn_Util_RemoverAcentuacao (@Texto VARCHAR(MAX))
RETURNS VARCHAR(MAX)
AS
BEGIN
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'Ó', 'O');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'ó', 'o');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'Ò', 'O');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'ò', 'o');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'Ô', 'O');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'ô', 'o');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'Õ', 'O');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'õ', 'o');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'Á', 'A');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'á', 'a');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'À', 'A');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'à', 'a');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'Â', 'A');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'â', 'a');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'Ã', 'A');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'ã', 'a');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'Ç', 'C');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'ç', 'c');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'É', 'E');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'é', 'e');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'Ê', 'E');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'ê', 'e');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'Í', 'I');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'í', 'i');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'Ú', 'U');
    SET @Texto = REPLACE(@Texto COLLATE Latin1_General_BIN, 'ú', 'u');
    RETURN @Texto;
END;
GO

-- SCRIPT DE TESTE: fn_Util_RemoverAcentuacao
WITH MOCK_TESTE AS (
    SELECT 'Avenida dos Holandeses, Óbidos, Centro Histórico (Próximo à Igreja).' AS TextoOriginal
)
SELECT 
    TextoOriginal,
    dbo.fn_Util_RemoverAcentuacao(TextoOriginal) AS Texto_Sem_Acentuacao
FROM MOCK_TESTE;
GO


-- 1.2. Remoção de Caracteres Especiais (Mantém apenas letras, números e espaços)
CREATE FUNCTION dbo.fn_Util_LimparCaracteresEspeciais (@Texto VARCHAR(MAX))
RETURNS VARCHAR(MAX)
AS
BEGIN
    DECLARE @Padrao VARCHAR(255) = '%[^a-zA-Z0-9 ]%'; 
    SET @Texto = @Texto COLLATE Latin1_General_BIN;
    
    WHILE PATINDEX(@Padrao, @Texto) > 0
    BEGIN
        SET @Texto = STUFF(@Texto, PATINDEX(@Padrao, @Texto), 1, '');
    END
    RETURN @Texto;
END;
GO

-- SCRIPT DE TESTE: fn_Util_LimparCaracteresEspeciais
WITH MOCK_TESTE AS (
    SELECT 'Rua do Giz, n° 45 – Centro Histórico!' AS TextoOriginal
)
SELECT 
    TextoOriginal,
    dbo.fn_Util_LimparCaracteresEspeciais(TextoOriginal) AS Texto_Sem_Especiais
FROM MOCK_TESTE;
GO


-- 1.3. Capitalização Inteligente de Strings (Equivalente ao InitCap - Primeira letra em maíuscula)
CREATE FUNCTION dbo.fn_Util_FormatInitCap (@Texto VARCHAR(MAX))
RETURNS VARCHAR(MAX)
AS
BEGIN
    DECLARE @Resultado VARCHAR(MAX) = '';
    DECLARE @Indice INT = 1;
    DECLARE @Caractere CHAR(1);
    
    SET @Texto = LOWER(RTRIM(LTRIM(@Texto)));
    WHILE @Indice <= LEN(@Texto)
    BEGIN
        SET @Caractere = SUBSTRING(@Texto, @Indice, 1);
        IF @Indice = 1 OR SUBSTRING(@Texto, @Indice - 1, 1) = ' '
            SET @Resultado = @Resultado + UPPER(@Caractere);
        ELSE
            SET @Resultado = @Resultado + @Caractere;
        SET @Indice = @Indice + 1;
    END
    RETURN @Resultado;
END;
GO

-- SCRIPT DE TESTE: fn_Util_FormatInitCap
WITH MOCK_TESTE AS (
    SELECT 'joão da silva aurélio' AS TextoOriginal
)
SELECT 
    TextoOriginal,
    dbo.fn_Util_FormatInitCap(TextoOriginal) AS Texto_Formatado_InitCap
FROM MOCK_TESTE;
GO


-- 1.4. Validação de String Puramente Numérica (Garante apenas dígitos de 0 a 9)
CREATE FUNCTION dbo.fn_Util_ApenasNumeros (@Texto VARCHAR(MAX))
RETURNS BIT -- Retorna 1 para Verdadeiro e 0 para Falso
AS
BEGIN
    -- Se o texto for nulo ou vazio, não é puramente numérico
    IF @Texto IS NULL OR LEN(RTRIM(LTRIM(@Texto))) = 0
        RETURN 0;

    -- Se encontrar qualquer caractere que NÃO seja de 0 a 9, PATINDEX retorna maior que 0
    IF PATINDEX('%[^0-9]%', @Texto) > 0
        RETURN 0; 

    RETURN 1; -- Contém estritamente apenas números
END;
GO

-- SCRIPT DE TESTE: fn_Util_ApenasNumeros
WITH MOCK_TESTE AS (
    SELECT '12345678900' AS Valido, '123.456.789-00' AS Invalido
)
SELECT 
    Valido AS Caso_1_Original, dbo.fn_Util_ApenasNumeros(Valido) AS Caso_1_Resultado,
    Invalido AS Caso_2_Original, dbo.fn_Util_ApenasNumeros(Invalido) AS Caso_2_Resultado
FROM MOCK_TESTE;
GO
